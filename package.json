{
  "name": "mental-tachometer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "extension:pack": "powershell -NoProfile -Command \"$d='extension-dist'; if(Test-Path $d){Remove-Item -Recurse -Force $d}; Copy-Item -Recurse extension $d; Compress-Archive -Path \\\"$d/*\\\" -DestinationPath \\\"$d/mental-tachometer.zip\\\"; Write-Host \\\"Packaged: $d/mental-tachometer.zip\\\"\""
  },
  "dependencies": {
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-toggle": "^1.1.0",
    "@react-three/drei": "^9.117.0",
    "@react-three/fiber": "^8.17.0",
    "chart.js": "^4.4.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "resend": "^6.12.4",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.168.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.168.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.4.0"
  }
}
