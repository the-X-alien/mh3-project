{
  "manifest_version": 3,
  "name": "Mental Tachometer",
  "version": "1.0.0",
  "description": "A real-time cognitive load monitor that tracks browsing patterns to detect and prevent burnout.",
  "homepage_url": "https://mh3-project.vercel.app",
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "permissions": [
    "tabs",
    "storage",
    "idle",
    "alarms",
    "notifications",
    "scripting",
    "sidepanel"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Mental Tachometer",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "options_ui": {
    "page": "popup/index.html",
    "open_in_tab": false
  },
  "side_panel": {
    "default_path": "popup/index.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "mental-tachometer@mh3-project",
      "strict_min_version": "121.0"
    }
  }
}
