# ─── Client (Vite — safe to expose, must be prefixed VITE_) ───
VITE_SUPABASE_URL=https://abiizncmbcgqodkvnucg.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Server (Vercel functions — DO NOT prefix with VITE_) ───
# Resend API key for sending check-in emails
RESEND_API_KEY=re_xxx
# Verified sender (defaults to Shanti <onboarding@resend.dev> if unset)
RESEND_FROM=Shanti <onboarding@resend.dev>

# Supabase service-role key — used ONLY by the cron function to read all
# due schedules (bypasses RLS). Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=some-long-random-string
